-- Main Loop (Optimasi Ping 90-110ms)
task.spawn(function()
    while task.wait(0.1) do
        local char = LP.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if _G.AutoFarm and hrp then
            -- 1. Auto Dig
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
            
            -- 2. Auto Collect (Ping Friendly)
            for _, v in pairs(workspace.Collectibles:GetChildren()) do
                if (v.Position - hrp.Position).Magnitude < 25 then
                    hrp.CFrame = v.CFrame
                    task.wait(0.05)
                    break
                end
            end
            
            -- 3. Jual Madu jika Tas Penuh (>95%)
            local stats = LP:FindFirstChild("CoreStats")
            if stats and (stats.Pollen.Value / stats.Capacity.Value) > 0.95 then
                local hive = workspace.Honeycombs:FindFirstChild(LP.Name)
                if hive then
                    hrp.CFrame = hive.SpawnLocation.CFrame + Vector3.new(0, 3, 0)
                    task.wait(0.5)
                    ReplicatedStorage.Events.PlayerHiveCommand:FireServer("MakeHoney")
                    repeat task.wait(1) until (stats.Pollen.Value / stats.Capacity.Value) < 0.05
                    
                    if _G.AutoQuest then
                        -- Ke Black Bear setelah jual madu
                        hrp.CFrame = CFrame.new(-84, 4, 340)
                        task.wait(0.5)
                        ReplicatedStorage.Events.PlayerQuestEvent:FireServer("AcceptQuest", "Black Bear")
                    end

                    if _G.AutoBuy then
                        ReplicatedStorage.Events.ItemPackageEvent:FireServer("Buy", {["Type"] = "Collector", ["Name"] = "Pollen Dipper"})
                    end
                end
            end
        end
    end
end)

